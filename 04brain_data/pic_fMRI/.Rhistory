# 计算描述性统计量（均值和标准误）
sumrepdat <- summarySE(
Main_effect_membership,
measurevar = "Thalamus_dACC",
groupvars = c("membership")
)
## 图形参数设置
w <- 5  # 宽度
h <- 5  # 高度
